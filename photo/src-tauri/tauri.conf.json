{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Face-Efface Photo",
  "version": "1.0.0",
  "identifier": "com.xipilom.face-efface-photo",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Face-Efface Photo — XiPiNOCODE",
        "width": 1100,
        "height": 750,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "shortDescription": "Floutage de visages sur photo — 100% local",
    "longDescription": "Face-Efface Photo permet de flouter automatiquement les visages sur vos photos, entièrement sur votre ordinateur, sans envoyer aucune donnée sur internet.",
    "publisher": "XiPiNOCODE — Bruno Molinari",
    "copyright": "© 2025 XiPiNOCODE"
  }
}
